{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build ReciPro (Debug|x64)",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/ReciPro/ReciPro.csproj",
        "-c",
        "Debug",
        "-p:Platform=x64"
      ],
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "build ReciPro (Release|x64)",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/ReciPro/ReciPro.csproj",
        "-c",
        "Release",
        "-p:Platform=x64"
      ],
      "problemMatcher": "$msCompile",
      "group": "build"
    }
  ]
}