  <data name="numericBoxDistance.ToolTip" xml:space="preserve">
    <value>Imposta la seconda lunghezza di camera
(distanza campione-rivelatore) in mm.</value>
  </data>
  <data name="numericBoxFootX.ToolTip" xml:space="preserve">
    <value>Imposta la coordinata x (in pixel) del punto di
appoggio dove il fascio diretto colpisce il rivelatore.</value>
  </data>
  <data name="numericBoxFootY.ToolTip" xml:space="preserve">
    <value>Imposta la coordinata y (in pixel) del punto di
appoggio dove il fascio diretto colpisce il rivelatore.</value>
  </data>
