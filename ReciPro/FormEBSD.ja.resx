  <data name="buttonViewFromZ.ToolTip" xml:space="preserve">
    <value>3D幾何ビューの視点を、Z軸(電子線方向)に設定します。</value>
  </data>
  <data name="buttonViewQuarter.ToolTip" xml:space="preserve">
